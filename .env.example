# --- Database -------------------------------------------------------------
# Local dev (default): SQLite file, zero setup.
DATABASE_URL="file:./dev.db"
#
# Production on Vercel: use a free Postgres (Neon / Supabase / Vercel Postgres)
# and change `provider = "sqlite"` to `provider = "postgresql"` in
# prisma/schema.prisma. Example:
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Auth (NextAuth) ------------------------------------------------------
# Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# The canonical URL of the deployment. Locally this is http://localhost:3000.
# On Vercel, set it to your production domain (https://your-app.vercel.app).
NEXTAUTH_URL="http://localhost:3000"
