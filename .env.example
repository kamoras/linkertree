# --- Database -------------------------------------------------------------
# PostgreSQL connection string. Local dev can use a Docker Postgres (see README)
# or a free dev DB from Neon / Supabase. Production uses the same.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/linkertree"
#
# Hosted Postgres usually requires SSL, e.g.:
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Auth (NextAuth) ------------------------------------------------------
# Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# The canonical URL of the deployment. Locally this is http://localhost:3000.
# On Vercel, set it to your production domain (https://your-app.vercel.app).
NEXTAUTH_URL="http://localhost:3000"
