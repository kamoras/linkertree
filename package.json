{
  "name": "linkertree",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Open-source, self-hostable Linktree alternative. MIT licensed and free to deploy on Vercel.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma db push && next build",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "bcryptjs": "^3.0.3",
    "next": "^16.2.11",
    "next-auth": "^4.24.15",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.11",
    "postcss": "^8.5.21",
    "prisma": "^7.9.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  }
}
